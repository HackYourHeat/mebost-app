# ══════════════════════════════════════════════════════
#  Hải Đăng — Environment Variables
#  Local: copy thành .env
#  Railway: Settings → Variables (không commit .env)
# ══════════════════════════════════════════════════════

# ── BẮT BUỘC ──────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
SECRET_KEY=your_random_secret_key_min_32_chars_here

# ── MODEL ─────────────────────────────────────────────
MODEL_NAME=deepseek/deepseek-chat
# Alternatives: openai/gpt-4o-mini, anthropic/claude-haiku-4-5-20251001

# ── SERVER ────────────────────────────────────────────
PORT=8080
# Railway inject PORT tự động — không cần set trên Railway

# ── LOGGING ───────────────────────────────────────────
LOG_LEVEL=INFO
# DEBUG: chi tiết hơn (chỉ dùng staging)
# WARNING: chỉ lỗi (production khi đã ổn định)

# ── ADMIN DASHBOARD ───────────────────────────────────
ADMIN_KEY=change_this_before_production
# URL: https://your-app.railway.app/admin/soul?key=<ADMIN_KEY>
# Đổi ngay trước khi deploy production

# ── DATABASE ──────────────────────────────────────────
# OPTION A — SQLite + Railway Volume (đơn giản, phù hợp MVP):
#   1. Railway → Service → Volumes → Add Volume
#   2. Mount path: /data
#   3. Không cần set DATABASE_URL — db.py tự detect /data/haidang.db
#
# OPTION B — PostgreSQL (khuyến nghị cho production):
#   1. Railway → Project → Add Plugin → PostgreSQL
#   2. DATABASE_URL tự inject — không cần copy tay
#   3. Bỏ comment psycopg2-binary trong requirements.txt
#   4. Chạy: pip install psycopg2-binary
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── EMAIL ─────────────────────────────────────────────
# Để trống = dev mode (email log ra console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ── ENVIRONMENTS ──────────────────────────────────────
# Railway tự inject RAILWAY_ENVIRONMENT khi deploy
# Không cần set tay — dùng để phân biệt staging vs production
# RAILWAY_ENVIRONMENT=production

# ══════════════════════════════════════════════════════
#  ROLLBACK TRIGGERS — chốt trước khi mở production
# ══════════════════════════════════════════════════════
#  Xem smoke_test.py để biết cách đo
#
#  - Response "lạnh" (< 30 chars):  > 30% → rollback
#  - Context miss (memory bị quên): > 20% → rollback
#  - p95 latency:                   > 5s  → rollback
#  - Error rate:                    > 5%  → rollback
